# x-chip-tinycore-xorg build configuration. Sourced by scripts/*.sh.
# Every value is overridable from the environment.

# --- Kernel -----------------------------------------------------------------
# Latest longterm target. 7.1.x is stable, but not longterm.
KERNEL_VERSION=${KERNEL_VERSION:-6.18.37}
KERNEL_MAJOR=${KERNEL_VERSION%%.*}
KERNEL_LOCALVERSION=${KERNEL_LOCALVERSION:--chip-tc}
KERNEL_TARBALL_SHA256=${KERNEL_TARBALL_SHA256:-}

# --- TinyCore / CorePure base (armhf, maintained) ---------------------------
# The release image is RPi-flavored; we keep ONLY its board-agnostic CorePure
# rootfs and point the device at the live .tcz repo for extensions.
TINYCORE_VERSION=${TINYCORE_VERSION:-16.0.0}
TINYCORE_BASE_FILE=${TINYCORE_BASE_FILE:-piCore-${TINYCORE_VERSION}.img.gz}
TINYCORE_BASE_URL=${TINYCORE_BASE_URL:-http://tinycorelinux.net/16.x/armhf/release/RPi/${TINYCORE_BASE_FILE}}
TINYCORE_BASE_SHA256=${TINYCORE_BASE_SHA256:-0c4ea8b2a886ac24bb95d78b3b65715185c30cffc6faaa204ff84c894963d2ea}
TCZ_REPO=${TCZ_REPO:-http://tinycorelinux.net/16.x/armhf/tcz}
TC_MIRROR=${TC_MIRROR:-http://tinycorelinux.net}

# --- Cross toolchain (host = x86_64) ----------------------------------------
ARCH=arm
CROSS_COMPILE=${CROSS_COMPILE:-arm-linux-gnueabihf-}

# --- CHIP specifics ---------------------------------------------------------
DTB=${DTB:-sun5i-r8-chip.dtb}
# Reuse the board fixes from the sibling chip-debroot repo (single source of truth).
CHIP_KERNEL_PATCHES=${CHIP_KERNEL_PATCHES:-../chip-debroot/kernel_files}
CHIP_DTS_DIR=${CHIP_DTS_DIR:-../chip-debroot/devicetree}
X_CHIP_TOOLS_RELEASE_TAG=${X_CHIP_TOOLS_RELEASE_TAG:-installer-2026.06.19-181233}
X_CHIP_UBOOT_RELEASE_TAG=${X_CHIP_UBOOT_RELEASE_TAG:-uboot-2026.06.12-155011}
X_CHIP_OS_RELEASE_TAG=${X_CHIP_OS_RELEASE_TAG:-os-2026.06.23-031749}
X_CHIP_INITRD_SHA256=${X_CHIP_INITRD_SHA256:-5b8b392c095fd37472f9a08f1ed8f6cdbb6d6a04bb36a0696dbcd3033c0f3b25}
X_CHIP_SPL_SHA256=${X_CHIP_SPL_SHA256:-a2640b992973e0ff042ea37de543d89bf9f855d1b64e5f485657267980d5f3cb}
X_CHIP_UBOOT_DTB_SHA256=${X_CHIP_UBOOT_DTB_SHA256:-608a2b695a369f2f30a7c9a08ea503d4613d57940afc28f9484a32913d3cc8e8}
X_CHIP_UBOOT_WITH_SPL_SHA256=${X_CHIP_UBOOT_WITH_SPL_SHA256:-2068dd9ca2ca531fb5698d775bd516e3abd019e4624a71440b7cffa600b1b94a}
X_CHIP_POCKETCHIP_ROOTFS_SHA256=${X_CHIP_POCKETCHIP_ROOTFS_SHA256:-02eb73c012cc9ccb5618108d99e82dfd71325304e4095ea6444259496c0bd050}

# --- Runtime identity / network --------------------------------------------
PROJECT_GITHUB_OWNER=${PROJECT_GITHUB_OWNER:-marceloeatworld}
PROJECT_REPO_NAME=${PROJECT_REPO_NAME:-x-chip-tinycore-xorg}
PROJECT_REPO_URL=${PROJECT_REPO_URL:-https://github.com/${PROJECT_GITHUB_OWNER}/${PROJECT_REPO_NAME}}
CHIP_HOSTNAME=${CHIP_HOSTNAME:-chip}
SSH_USER=${SSH_USER:-chip}
SSH_UID=${SSH_UID:-1000}
SSH_GID=${SSH_GID:-1000}
# Public images build with PUBLIC_IMAGE=1. That mode forces no WiFi config and
# no SSH authorized_keys, then enables password SSH by default. Personal images
# stay key-only unless SSH_PASSWORD_AUTH=1.
PUBLIC_IMAGE=${PUBLIC_IMAGE:-0}
SSH_PASSWORD_AUTH=${SSH_PASSWORD_AUTH:-}
SSH_PASSWORD=${SSH_PASSWORD:-chip}
SSH_PASSWORD_HASH=${SSH_PASSWORD_HASH:-}
# Leave empty for a per-build random SHA-512 salt when password auth is enabled.
SSH_PASSWORD_SALT=${SSH_PASSWORD_SALT:-}
AUTHORIZED_KEYS_SOURCE=${AUTHORIZED_KEYS_SOURCE:-../flash/rootfs_trixie/home/chip/.ssh/authorized_keys}
EXTRA_FIRMWARE_SOURCE=${EXTRA_FIRMWARE_SOURCE:-../flash/rootfs_trixie/usr/lib/firmware}
KEYMAP_SOURCE=${KEYMAP_SOURCE:-../chip-debroot/deb_files/usr/local/share/keymaps/pocketchip.kmap}
LCD_BRIGHTNESS=${LCD_BRIGHTNESS:-6}
X_CHIP_DESKTOP_AUTOSTART=${X_CHIP_DESKTOP_AUTOSTART:-1}
X_CHIP_DESKTOP_WM=${X_CHIP_DESKTOP_WM:-jwm}
X_CHIP_DESKTOP_VT=${X_CHIP_DESKTOP_VT:-2}

# Keep secrets out of this tracked config. scripts/03-assemble-rootfs.sh sources
# this file if present, with xtrace disabled, so WiFi credentials do not leak to
# the build log.
SECRETS_ENV=${SECRETS_ENV:-./secrets.env}
WIFI_COUNTRY=${WIFI_COUNTRY:-PT}
WIFI_SSID=${WIFI_SSID:-}
REQUIRE_WIFI_CONFIG=${REQUIRE_WIFI_CONFIG:-1}
REQUIRE_AUTHORIZED_KEYS=${REQUIRE_AUTHORIZED_KEYS:-1}
PRESEED_TCZ=${PRESEED_TCZ:-1}

RTL8812AU_BUILD=${RTL8812AU_BUILD:-1}
RTL8812AU_AUTOLOAD=${RTL8812AU_AUTOLOAD:-0}
RTL8812AU_HOTPLUG=${RTL8812AU_HOTPLUG:-1}
RTL8812AU_REPO=${RTL8812AU_REPO:-https://github.com/aircrack-ng/rtl8812au.git}
RTL8812AU_COMMIT=${RTL8812AU_COMMIT:-734485506a30d6237c2deaad666a19f8ca5379f2}
RTL8812AU_PATCH=${RTL8812AU_PATCH:-../rtl8812au-pocketchip-driver/rtl8812au-kernel-6.12.patch}

# --- Output -----------------------------------------------------------------
OUT=${OUT:-xorg-rootfs.tar.gz}
